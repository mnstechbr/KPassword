+
+/* === KPassword v0.8.4 login desktop refinado START === */
+/* Topo: tema à esquerda, cofre no centro real e idioma à direita, sem textos quebrados. */
+.authLoginTools {
+  flex: 1 1 auto !important;
+  width: 100% !important;
+  min-width: 0 !important;
+}
+
+.authLoginTools .authThemeButton span:not(.authThemeIcon) {
+  display: none !important;
+}
+
+.authLoginTools .authThemeButtons {
+  width: auto !important;
+  max-width: none !important;
+  flex: 0 0 auto !important;
+}
+
+.authLoginTools .authThemeButton {
+  width: 40px !important;
+  min-width: 40px !important;
+  padding: 0 !important;
+  flex: 0 0 40px !important;
+}
+
+.authLoginTools .authThemeIcon {
+  width: 20px !important;
+  height: 20px !important;
+  font-size: 1rem !important;
+}
+
+@media (min-width: 981px) {
+  .authUtilityBar {
+    width: 100% !important;
+  }
+
+  .authLoginTools {
+    position: relative !important;
+    display: flex !important;
+    align-items: center !important;
+    justify-content: center !important;
+    min-height: 58px !important;
+    gap: 16px !important;
+  }
+
+  .authThemeSlot,
+  .authLanguageSlot {
+    position: absolute !important;
+    top: 50% !important;
+    transform: translateY(-50%) !important;
+  }
+
+  .authThemeSlot {
+    left: 0 !important;
+  }
+
+  .authLanguageSlot {
+    right: 0 !important;
+  }
+
+  .authVaultActions {
+    margin: 0 auto !important;
+    justify-self: auto !important;
+    flex-wrap: nowrap !important;
+    gap: 10px !important;
+  }
+
+  .authVaultActions .authToolButton {
+    min-width: 142px !important;
+    padding-inline: 18px !important;
+  }
+
+  .authVaultActions .authVaultSelect {
+    min-width: 156px !important;
+    max-width: 220px !important;
+  }
+
+  .authLanguageSlot .languageSelect.compact select {
+    width: 84px !important;
+    min-width: 84px !important;
+    text-align: center !important;
+    text-align-last: center !important;
+  }
+}
+
+/* Tela bloqueada desktop: logo e painel respiram juntos, sem o container parecer dividido em dois. */
+.authCard.authExperience.authLocked {
+  grid-template-columns: minmax(220px, 330px) minmax(360px, 440px) !important;
+  grid-template-rows: auto minmax(0, 1fr) auto !important;
+  column-gap: clamp(42px, 7vw, 96px) !important;
+  row-gap: clamp(18px, 3vh, 34px) !important;
+  align-items: center !important;
+  align-content: stretch !important;
+  justify-content: center !important;
+  padding-top: clamp(28px, 4vw, 52px) !important;
+  padding-bottom: clamp(28px, 4vw, 52px) !important;
+}
+
+.authLocked .authUtilityBar {
+  grid-column: 1 / -1 !important;
+  grid-row: 1 !important;
+}
+
+.authLocked .authLogoStage {
+  grid-column: 1 !important;
+  grid-row: 2 !important;
+  justify-self: end !important;
+  align-self: center !important;
+  width: auto !important;
+  min-width: 0 !important;
+}
+
+.authLocked .authLogoStage > .vaultLogo.lg {
+  width: clamp(150px, 16vw, 208px) !important;
+  height: clamp(150px, 16vw, 208px) !important;
+  border-radius: clamp(34px, 4vw, 48px) !important;
+}
+
+.authLocked .authUnlockPanel {

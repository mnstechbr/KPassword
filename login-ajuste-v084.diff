+}
+
+/* Fenda da logo: leve enquanto digita, mais evidente quando a senha foi validada. */
+.authLocked .authLogoStage > .vaultLogo.lg::before {
+  left: 50% !important;
+  top: 50% !important;
+  width: 5px !important;
+  height: 84% !important;
+  opacity: 0.18 !important;
+  transform: translate(-50%, -50%) scaleY(0.18) !important;
+  background:
+    linear-gradient(180deg,
+      rgba(125, 211, 252, 0),
+      rgba(125, 211, 252, 0.96) 24%,

+  box-shadow: 0 0 16px rgba(56, 189, 248, 0.18) !important;
+  z-index: 8 !important;
+}
+
+.authLocked.authUnlockTyping .authLogoStage > .vaultLogo.lg::before,
+.authLocked .authLogoStage > .vaultLogo.lg.opening::before {
+  width: 9px !important;
+  opacity: 0.82 !important;
+  transform: translate(-50%, -50%) scaleY(0.88) !important;
+  box-shadow:
+    0 0 18px rgba(56, 189, 248, 0.42),
+    0 0 40px rgba(124, 58, 237, 0.20) !important;
+}
+
+.authLocked.authUnlockSuccess .authLogoStage > .vaultLogo.lg::before {
+  animation: kpasswordRiftOpen 360ms cubic-bezier(.2, .9, .2, 1) both !important;
+}
+
+.authLocked.authUnlockSuccess .authLogoStage > .vaultLogo.lg::after {

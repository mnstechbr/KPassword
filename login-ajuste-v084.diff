+    drop-shadow(0 22px 38px rgba(0, 0, 0, 0.38))
+    drop-shadow(0 0 34px rgba(56, 189, 248, 0.22)) !important;
+}
+
+@keyframes kpasswordRiftOpen {
+  0% {
+    width: 5px;
+    opacity: 0.22;
+    transform: translate(-50%, -50%) scaleY(0.20);
+  }
+  46% {
+    width: 22px;
+    opacity: 1;
+    transform: translate(-50%, -50%) scaleY(1.08);
+  }
+  100% {
+    width: 14px;
+    opacity: 0.92;

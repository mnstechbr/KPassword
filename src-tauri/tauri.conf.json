{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KPassword",
  "version": "0.8.1",
  "identifier": "com.kpassword.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "KPassword",
        "label": "main",
        "width": 1120,
        "height": 720,
        "minWidth": 360,
        "minHeight": 520,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/sounds/metro-arrival.wav"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3QjkwMkM5ODJFODg2NTQKUldSVWh1aUN5UUs1bHhvQ0xHNnh4YW13NEUyS3JWZFpJNTdvcjRjdGlQbnNHaTg1MFMwc3BuY0IK",
      "endpoints": [
        "https://github.com/mnstechbr/KPassword/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
